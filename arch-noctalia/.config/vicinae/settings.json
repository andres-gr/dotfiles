{
  "$schema": "https://vicinae.com/schemas/config.json",
  "close_on_focus_loss": true,
  "pop_to_root_on_close": true,
  "activate_on_single_click": true,
  "font": {
    "normal": {
      "family": "Noto Sans",
      "size": 10.5
    }
  },
  "theme": {
    "dark": {
      "name": "noctalia"
    }
  },
  "telemetry": {
    "system_info": false
  },
  "launcher_window": {
    "opacity": 0.9,
    "client_side_decorations": {
      "enabled": true
    }
  },
  "keybinds": {
    "toggle-action-panel": "alt+K"
  },
  "favorites": [],
  "providers": {
    "applications": {
      "entrypoints": {
        "chromium": {
          "alias": "chrome"
        },
        "com.rtosta.zapzap": {
          "alias": "whatsapp"
        },
        "localsend": {
          "alias": "send"
        },
        "vesktop": {
          "alias": "discord"
        }
      }
    },
    "browser-extension": {
      "entrypoints": {
        "browse-tabs": {
          "enabled": false
        }
      }
    },
    "clipboard": {
      "enabled": false,
      "preferences": {
        "encryption": false,
        "eraseOnStartup": false,
        "ignorePasswords": true,
        "monitoring": false
      },
      "entrypoints": {
        "history": {
          "preferences": {
            "defaultAction": "copy"
          }
        }
      }
    },
    "core": {
      "entrypoints": {
        "sponsor": {
          "enabled": false
        }
      }
    },
    "files": {
      "entrypoints": {
        "search": {
          "alias": "f"
        }
      }
    },
    "power": {
      "entrypoints": {
        "hibernate": {
          "enabled": false
        },
        "lock": {
          "preferences": {
            "confirm": false,
            "customProgram": "qs -c noctalia-shell ipc call sessionMenu lock"
          }
        },
        "logout": {
          "preferences": {
            "confirm": false
          }
        },
        "power-off": {
          "alias": "shut",
          "preferences": {
            "confirm": false
          }
        },
        "reboot": {
          "alias": "res",
          "preferences": {
            "confirm": false
          }
        },
        "sleep": {
          "enabled": false,
          "preferences": {
            "confirm": true,
            "customProgram": "qs -c noctalia-shell ipc call sessionMenu lockAndSuspend"
          }
        },
        "soft-reboot": {
          "enabled": false
        },
        "suspend": {
          "alias": "sl",
          "preferences": {
            "confirm": false,
            "customProgram": "qs -c noctalia-shell ipc call sessionMenu lockAndSuspend"
          }
        }
      }
    },
    "shortcuts": {
      "enabled": true
    }
  }
}
