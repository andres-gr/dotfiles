[Unit]
Description=Remove Polaris GPU from PCI bus
After=systemd-udevd.service
Before=display-manager.service

[Service]
Type=oneshot
ExecStart=/bin/sh -c "echo 1 > /sys/bus/pci/devices/0000:05:00.1/remove"
ExecStart=/bin/sh -c "echo 1 > /sys/bus/pci/devices/0000:05:00.0/remove"

[Install]
WantedBy=multi-user.target
