{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context-mode": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "-y",
        "context-mode"
      ]
    },
    "repomix": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "-y",
        "repomix",
        "--mcp"
      ]
    }
  },
  "plugin": [
    "context-mode",
    "repomix",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "instructions": [
    "instructions/caveman.md",
    "instructions/context-mode.md"
  ]
}
