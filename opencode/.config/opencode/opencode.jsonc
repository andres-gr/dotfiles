{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context-mode": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "-y",
        "context-mode"
      ]
    },
    "repomix": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "-y",
        "repomix",
        "--mcp"
      ]
    },
    "serena": {
      "type": "local",
      "command": [
        "serena",
        "start-mcp-server",
        "--project-from-cwd",
        "--context=ide"
      ],
      "enabled": false
    }
  },
  "plugin": [
    "context-mode",
    "repomix",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4-tools": {
          "name": "gemma4-tools",
        }
      }
    }
  },
  "instructions": [
    "instructions/caveman.md",
    "instructions/context-mode.md"
  ]
}
