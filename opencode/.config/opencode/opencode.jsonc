{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context-mode": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "-y",
        "context-mode"
      ]
    },
    "repomix": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "-y",
        "repomix",
        "--mcp"
      ]
    }
  },
  "plugin": [
    "context-mode",
    "repomix"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4-tools": {
          "name": "gemma4-tools",
        }
      }
    }
  },
  "instructions": ["instructions/context-mode.md"]
}
