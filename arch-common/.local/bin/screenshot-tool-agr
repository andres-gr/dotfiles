#!/usr/bin/env bash
# screenshot — universal Wayland capture → satty annotation
# Usage: screenshot [full|screen|window|region]
# Deps:  grim slurp satty wl-clipboard jq libnotify
# Opt:   hyprpicker (freeze on Hyprland)
#        wayfreeze (freeze on Niri / generic wlroots)

set -euo pipefail

# ── Dependency checks ───────────────────────────────────────────────────────

check_deps() {
  local missing=()
  local required=(grim slurp satty wl-copy jq notify-send)

  for cmd in "${required[@]}"; do
    command -v "$cmd" &>/dev/null || missing+=("$cmd")
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "screenshot: missing required dependencies: ${missing[*]}" >&2
    echo "  pacman: grim slurp wl-clipboard jq libnotify" >&2
    echo "  aur:    satty" >&2
    exit 1
  fi
}

check_deps

# ── Output dir setup ────────────────────────────────────────────────────────

SAVE_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots"

mkdir -p "$SAVE_DIR" || { echo "screenshot: cannot create $SAVE_DIR" >&2; exit 1; }

if [[ ! -w "$SAVE_DIR" ]]; then
  echo "screenshot: no write permission on $SAVE_DIR" >&2
  exit 1
fi

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
OUTFILE="$SAVE_DIR/screenshot_$TIMESTAMP.png"

FREEZE_PID=""

# ── Compositor detection ────────────────────────────────────────────────────

COMPOSITOR="generic"
[[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]] && COMPOSITOR="hyprland"
[[ -n "${NIRI_SOCKET:-}" ]]                 && COMPOSITOR="niri"

# ── Freeze helpers ──────────────────────────────────────────────────────────

freeze_screen() {
  case "$COMPOSITOR" in
  hyprland)
    # Use wayfreeze instead of hyprpicker (doesn't block ESC)
    if command -v wayfreeze &>/dev/null; then
      wayfreeze &
      FREEZE_PID=$!
      sleep 0.1
    fi
    ;;
  niri|generic)
    if command -v wayfreeze &>/dev/null; then
      wayfreeze &
      FREEZE_PID=$!
      sleep 0.1
    fi
    ;;
  esac
}

unfreeze_screen() {
  if [[ -n "$FREEZE_PID" ]]; then
    kill "$FREEZE_PID" 2>/dev/null || true
    FREEZE_PID=""
  fi
}

trap unfreeze_screen EXIT

# ── Notification helper — xdg-open decoupled from pipe ─────────────────────

notify_done() {
  local mode="$1"
  local file="$2"

  [[ -f "$file" ]] || return 0
  command -v notify-send &>/dev/null || return 0

  local label
  case "$mode" in
    full)   label="Full screen" ;;
    screen) label="Output" ;;
    window) label="Window" ;;
    region) label="Region" ;;
    *)      label="Screenshot" ;;
  esac

  # Capture the action response into a variable so xdg-open
  # is not backgrounded inside the pipe — avoids the race with EXIT trap
  local action
  action=$(notify-send \
      --app-name="screenshot" \
      --icon="$file" \
      --action="open=Open" \
    "Screenshot saved" "$label → $(basename "$file")")

  [[ "$action" == "open" && -f "$file" ]] && xdg-open "$file" &
}

# ── Satty pipe ──────────────────────────────────────────────────────────────

pipe_to_satty() {
  satty \
    --filename - \
    --output-filename "$OUTFILE" \
    --copy-command "wl-copy" \
    --disable-notifications
}

# ── Capture modes ───────────────────────────────────────────────────────────

MODE="${1:-region}"

case "$MODE" in

  full|all)
    notify-send --app-name="screenshot" --transient \
      "Screenshot" "Capturing all outputs…" 2>/dev/null
    sleep 0.1
    grim -c - | pipe_to_satty
    notify_done "full" "$OUTFILE"
    ;;

  screen|output|monitor)
    OUTPUT=$(slurp -o -f "%o" 2>/dev/null) || { echo "Cancelled"; exit 0; }
    sleep 0.1
    grim -o "$OUTPUT" -c - | pipe_to_satty
    notify_done "screen" "$OUTFILE"
    ;;

window)
    case "$COMPOSITOR" in
    hyprland)
      # Get all visible windows from hyprctl, pass to slurp for selection
      WINDOWS=$(hyprctl clients -j 2>/dev/null | jq -r '
        .[] | select(.workspace.id > 0 and .mapped == true) |
        "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"
      ' 2>/dev/null)

      if [[ -n "$WINDOWS" ]]; then
        GEOM=$(echo "$WINDOWS" | slurp) || { echo "Cancelled"; exit 0; }
      else
        GEOM=$(slurp) || { echo "Cancelled"; exit 0; }
      fi
      ;;
    niri)
      # Niri: capture focused window to temp file, then pipe to satty
      # Save current clipboard before Niri overwrites it
      ORIGINAL_CLIP=$(wl-paste 2>/dev/null || true)

      TEMP_CAP="$SAVE_DIR/niri_cap_$$.png"
      niri msg action screenshot-window --path "$TEMP_CAP" 2>/dev/null || {
        echo "Failed to capture"
        exit 1
      }

      # Wait for file
      for i in {1..30}; do
        [[ -f "$TEMP_CAP" ]] && break
        sleep 0.1
      done

      if [[ ! -f "$TEMP_CAP" ]]; then
        echo "Screenshot failed"
        exit 1
      fi

      # Delete the screenshot from cliphist (newest entry)
      CLIPHIST_NEWEST=$(cliphist list 2>/dev/null | head -1 | awk '{print $1}' || echo "")
      if [[ -n "$CLIPHIST_NEWEST" ]]; then
        echo "$CLIPHIST_NEWEST" | cliphist delete 2>/dev/null || true
      fi

      # Restore original clipboard
      if [[ -n "$ORIGINAL_CLIP" ]]; then
        printf '%s' "$ORIGINAL_CLIP" | wl-copy 2>/dev/null || true
      fi

      # Pipe to satty (handles save/copy/discard)
      cat "$TEMP_CAP" | pipe_to_satty
      rm -f "$TEMP_CAP"
      notify_done "window" "$OUTFILE"
      exit 0
      ;;
    *)
      # Generic: slurp for region selection
      GEOM=$(slurp) || { echo "Cancelled"; exit 0; }
      ;;
    esac

    sleep 0.1
    grim -g "$GEOM" -c - | pipe_to_satty
    notify_done "window" "$OUTFILE"
    ;;

  region)
    # Skip freeze for region - quick selection, ESC works directly
    GEOM=$(slurp) || { echo "Cancelled"; exit 0; }
    grim -g "$GEOM" - | pipe_to_satty
    notify_done "region" "$OUTFILE"
    ;;

    *)
      echo "Usage: screenshot [full|screen|window|region]"
      exit 1
      ;;
  esac
