#!/bin/env bash

# window-grab — simulate Super+LMB hold via F20 mouse button
# Grabs focused window on F20 press, releases on F20 release
export YDOTOOL_SOCKET=/tmp/ydotool.sock

# guard against concurrent runs
LOCK=/tmp/niri-grab.pid
if [[ -f "$LOCK" ]] && kill -0 "$(cat "$LOCK")" 2>/dev/null; then
  exit 0
fi
echo $$ > "$LOCK"

# always release Super+LMB on exit, even if killed
cleanup() {
  ydotool click 0x80
  sleep 0.02
  ydotool key 125:0
  rm -f "$LOCK"
}
trap cleanup EXIT

# find Logitech kbd device — prefer if01-event-kbd, fall back to bare event-kbd
DEVICE=$(find /dev/input/by-id/ -name "*Logitech_USB_*-event-mouse" 2>/dev/null | head -1)
[[ -z "$DEVICE" ]] && \
  DEVICE=$(find /dev/input/by-id/ -name "*Logitech*event-kbd" 2>/dev/null | head -1)

if [[ -z "$DEVICE" ]]; then
  notify-send "window-grab" "No Logitech keyboard input device found" 2>/dev/null || true
  exit 1
fi

# grab: Super down + LMB down
ydotool key 125:1
ydotool click 0x40

# block until F20 key release (value 0), ignore repeats (value 2)
python3 - "$DEVICE" << 'PYEOF'
import struct, sys

DEVICE = sys.argv[1]
EV_KEY = 1
KEY_F20 = 190
EVENT_FMT = "llHHi"
EVENT_SIZE = struct.calcsize(EVENT_FMT)

with open(DEVICE, 'rb') as f:
    while True:
        data = f.read(EVENT_SIZE)
        if len(data) < EVENT_SIZE:
            break
        _, _, etype, code, value = struct.unpack(EVENT_FMT, data)
        if etype == EV_KEY and code == KEY_F20 and value == 0:
            break
PYEOF

# cleanup trap fires here: LMB up + Super up + lock removal
