#!/bin/env bash
VIDEO="$HOME/.local/assets/splashes/$STARTUP_SPLASH"
DURATION="$STARTUP_SPLASH_DURATION"
VOLUME="$STARTUP_SPLASH_VOLUME" || "10"

# ── monitor detection ─────────────────────────────────────────
if [[ "$XDG_CURRENT_DESKTOP" == "niri" ]]; then
  ALL=$(niri msg -j outputs 2>/dev/null | jq -r 'to_entries[].value.name')
  PRIMARY_JSON=$(niri msg -j outputs 2>/dev/null | jq -r 'to_entries[].value | select(.logical.x == 0)')
  RES=$(echo "$PRIMARY_JSON" | jq -r '"\(.logical.width)x\(.logical.height)"')
  MONITOR=$(echo "$PRIMARY_JSON" | jq -r '.name')
  TEMP_BINDS="$HOME/.config/niri/splash-temp-binds.kdl"
elif [[ "$XDG_CURRENT_DESKTOP" == "Hyprland" ]]; then
  ALL=$(hyprctl monitors -j 2>/dev/null | jq -r '.[].name')
  PRIMARY_JSON=$(hyprctl monitors -j 2>/dev/null | jq -r '.[] | select(.id == 0) | {name,height,width}')
  RES=$(echo "$PRIMARY_JSON" | jq -r '"\(.width)x\(.height)"')
  MONITOR=$(echo "$PRIMARY_JSON" | jq -r '.name')
  TEMP_BINDS="$HOME/.config/hypr/splash-temp-binds.conf"
else
  exit 0
fi

# ── bind helpers ──────────────────────────────────────────────
SELF_PID=$$

bind_keys() {
  if [[ "$XDG_CURRENT_DESKTOP" == "niri" ]]; then
    cat > "$TEMP_BINDS" <<EOF
binds {
  Escape { spawn-sh "kill -TERM $SELF_PID"; }
  MouseLeft { spawn-sh "kill -TERM $SELF_PID"; }
  MouseRight { spawn-sh "kill -TERM $SELF_PID"; }
  Return { spawn-sh "kill -TERM $SELF_PID"; }
  Space { spawn-sh "kill -TERM $SELF_PID"; }
}
cursor {
  hide-after-inactive-ms 1
}
EOF
  elif [[ "$XDG_CURRENT_DESKTOP" == "Hyprland" ]]; then
    cat > "$TEMP_BINDS" <<EOF
bind = , ESCAPE, exec, kill -TERM $SELF_PID
bind = , mouse:272, exec, kill -TERM $SELF_PID
bind = , mouse:273, exec, kill -TERM $SELF_PID
bind = , RETURN, exec, kill -TERM $SELF_PID
bind = , SPACE, exec, kill -TERM $SELF_PID
cursor {
  invisible = true
}
EOF
  fi
}

unbind_keys() {
  : > "$TEMP_BINDS"
}

# ── cleanup ───────────────────────────────────────────────────
cleanup() {
  if [[ "$XDG_CURRENT_DESKTOP" == "niri" ]]; then
    niri msg action do-screen-transition
  fi

  pkill -f mpvpaper 2>/dev/null || true
  unbind_keys
  rm -f /tmp/splash-black.png /tmp/splash.pid
}

# ── main ──────────────────────────────────────────────────────
pkill -f mpvpaper 2>/dev/null || true
sleep 0.2

echo $$ > /tmp/splash.pid

magick -size "$RES" xc:black /tmp/splash-black.png

mpvpaper -l overlay -o "--panscan=1 --af=volume=+${VOLUME}dB" "$MONITOR" "$VIDEO" &

for MON in $(echo "$ALL" | grep -v "^$MONITOR$"); do
  mpvpaper -l overlay -o "--loop" "$MON" /tmp/splash-black.png &
done

trap cleanup EXIT TERM INT

bind_keys

sleep "$DURATION" &
SLEEP_PID=$!
wait $SLEEP_PID

exit 0
