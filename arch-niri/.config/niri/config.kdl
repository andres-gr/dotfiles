# Niri configuration
#
# This is a placeholder config for Niri compositor.
# See https://github.com/YaLTeR/niri for documentation.
#
# TODO: Customize for your setup

// Workspace configuration
workspaces {
    // Default number of workspaces
    columns 5
}

// Output configuration
output {
    // Enable fractional scaling
    // scale 1.5
}

// Input configuration
input {
    // Trackpad natural scrolling
    // trackpad natural-scroll true

    // Keyboard repeat rate
    repeat-delay 35
    repeat-rate 50
}

// Window rules
// window-rules {
// }

// Cursor configuration
cursor {
    // hide-when-typing true
}
